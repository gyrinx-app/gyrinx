# Copy this file to `secrets.auto.tfvars` (gitignored) and fill in the
# real values. `*.auto.tfvars` is auto-loaded by Terraform during
# plan/apply, so the secrets reach the spacelift provider without any
# shell env wrangling.
#
# Values come from the Spacelift API-key config file Spacelift emails
# you after creating an admin key in the UI:
#   Settings -> API keys -> create key -> download config file.
#
# Example file:
#   ~/Downloads/api-key-gyrinx-spacelift-<your-name>.config

spacelift_api_key_id     = "01KRVR6TP31F6BZKP6717HW7YM"
spacelift_api_key_secret = "REPLACE-ME-FROM-THE-CONFIG-FILE"
