{
  "color": {
    "primary": {
      "value": "#0771ea",
      "scss": "$blue",
      "bootstrap": "--bs-primary",
      "role": "Primary actions, XP/credits badges"
    },
    "success": {
      "value": "#1a7b49",
      "scss": "$green",
      "bootstrap": "--bs-success",
      "role": "Active state, confirmations"
    },
    "danger": {
      "value": "#cb2b48",
      "scss": "$red",
      "bootstrap": "--bs-danger",
      "role": "Dead state, errors, destructive actions"
    },
    "warning": {
      "value": "#e8a10a",
      "scss": "$yellow",
      "bootstrap": "--bs-warning",
      "role": "Injured/captured state, highlights"
    },
    "info": {
      "value": "#10bdd3",
      "scss": "$cyan",
      "bootstrap": "--bs-info",
      "role": "Informational callouts"
    },
    "text-secondary": {
      "value": "var(--bs-secondary-color)",
      "scss": "$gy-text-muted",
      "bootstrap": "text-secondary",
      "role": "De-emphasised text (replaces text-muted)"
    },
    "dot-size": {
      "value": "10px",
      "scss": "$gy-dot-size",
      "role": "Standardised colour dot indicator"
    }
  },
  "typography": {
    "display": {
      "size": "2.5rem",
      "weight": "500",
      "line-height": "1.2",
      "class": "display-1",
      "role": "Hero headings (rarely used)"
    },
    "h1": {
      "size": "2rem",
      "weight": "500",
      "line-height": "1.2",
      "class": "h1",
      "role": "Page titles on index pages"
    },
    "h2": {
      "size": "1.75rem",
      "weight": "500",
      "line-height": "1.2",
      "class": "h2",
      "role": "Rarely used directly"
    },
    "h3": {
      "size": "1.25rem",
      "weight": "500",
      "line-height": "1.2",
      "class": "h3",
      "role": "Page titles on sub-pages (h1.h3)"
    },
    "h4": {
      "size": "1.125rem",
      "weight": "500",
      "line-height": "1.2",
      "class": "h4",
      "role": "Section headings"
    },
    "h5": {
      "size": "1rem",
      "weight": "500",
      "line-height": "1.2",
      "class": "h5",
      "role": "Sub-section headings, card headers"
    },
    "body": {
      "size": "0.875rem",
      "weight": "400",
      "line-height": "1.5",
      "class": null,
      "role": "Default body text (base font size)"
    },
    "fs-7": {
      "size": "0.75rem",
      "weight": "400",
      "line-height": "1.5",
      "class": "fs-7",
      "role": "Small text, table cells, metadata. Canonical small text class."
    },
    "caps-label": {
      "size": "0.75rem",
      "weight": "600",
      "line-height": "1.5",
      "class": "caps-label",
      "role": "Section sub-headers. Uppercase, tracked, semibold."
    }
  },
  "spacing": {
    "0": { "value": "0", "bootstrap": "0" },
    "1": { "value": "0.25rem", "bootstrap": "1" },
    "2": { "value": "0.5rem", "bootstrap": "2" },
    "3": { "value": "1rem", "bootstrap": "3" },
    "4": { "value": "1.5rem", "bootstrap": "4" },
    "5": { "value": "3rem", "bootstrap": "5" }
  },
  "spacing-semantic": {
    "form-gap": { "value": "gap-3", "role": "Form pages, edit views" },
    "listing-gap": { "value": "gap-4", "role": "Index/listing pages" },
    "detail-gap": { "value": "gap-5", "role": "Detail pages (list, campaign)" }
  },
  "layout": {
    "form-page": {
      "classes": "col-12 col-md-8 col-lg-6",
      "role": "Edit forms, settings"
    },
    "list-page": { "classes": "col-lg-12", "role": "Index pages, listings" },
    "detail-page": {
      "classes": "col-lg-12 px-0",
      "role": "Detail pages with sections"
    },
    "sidebar-page": {
      "classes": "row g-4",
      "role": "Lore, notes pages with TOC"
    }
  },
  "breakpoints": {
    "sm": "576px",
    "md": "768px",
    "lg": "992px",
    "xl": "1200px"
  }
}
